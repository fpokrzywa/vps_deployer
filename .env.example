# Admin password for the deployer UI (single user). Use a long, strong value.
ADMIN_PASSWORD="change-me-to-something-strong"

# Secret used to sign session cookies. Generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-openssl-rand-base64-32"

# Port the app listens on (default 4500).
PORT=4500

# --- Optional: override only if this VPS is laid out differently ---
# Directory holding the proxy docker-compose.yml (apps are registered here):
# DEPLOYER_PROXY_DIR="/root/prxyman"
# Where app repos are cloned:
# DEPLOYER_APPS_ROOT="/root"
# Full path to the proxy compose (defaults to $DEPLOYER_PROXY_DIR/docker-compose.yml):
# DEPLOYER_COMPOSE_PATH="/root/prxyman/docker-compose.yml"
# Flutter SDK bin dir (for static-flutter builds):
# DEPLOYER_FLUTTER_BIN="/root/flutter/bin"
# Compose services treated as infrastructure (never listed as sites):
# DEPLOYER_INFRA_SERVICES="npm,oauth2-proxy"
